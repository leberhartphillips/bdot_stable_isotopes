# Ignore everything in this repository by default.
/*

# Keep this ignore file and the target Quarto document.
!/.gitignore
!/AGENTS.md
!/DATA_MANIFEST.md
!/bdot_stable_isotopes2.qmd
!/R/
!/R/*
!/scripts/
!/scripts/*

# Keep only the in-repo datasets that bdot_stable_isotopes2.qmd reads.
!/data/
/data/*
!/data/old file versions/
/data/old file versions/*
!/data/old file versions/Master_SI_Feathers_LEH_Sept24_v1_SB_v3_sample wts added.xls
!/data/Master_TCEA_H_SI_Batch 1_triplicate breast feathers_LEH_Nov25_SB.xls
!/data/Master_TCEA_O_SI_Breast Feathers_Replication_Batch 4_LEH_Sept25_SB.xls
!/data/MASTER_museum_ALL SAMPLES INVENTORY_banded_dotterels_v4.xlsx
!/data/CNOH_museum_samples_201125.rds
!/data/Master_SI_Replicate test Feathers_N_9_LEH_Jan25_v1_SB.xls
!/data/Master_EA_C_N_SI_Batch 3 Breast feathers_shaft and barb comparison_LEH_Sept25_v1_SB.xls
!/data/Master_EA_C_N_SI_Batch 3 vane_barb and Batch 4 Breast Feathers_LEH_Sept25_v1_SB.xls
!/data/Master_TCEA_H_SI_BATCH 4 BREAST Feathers_LE_Nov25_v1.xls
!/data/LIMS_251105_MaxPlanck_Eberhart-Hertel.xlsx
!/data/Master_EA_C_N_SI_Batch 5 Breast and Primary Feathers_LEH_Repeats added_April25_v1_SB_v2.xls

# Keep the local output the document reads back in later.
!/output/
/output/*
!/output/roc_all.rds

# Keep documentation-only cleanup additions.
!/data/derived/
!/data/derived/*
!/data/derived/qc/
!/data/derived/qc/*

